generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  MANUFACTURER
  DISTRIBUTOR
  PHARMACY
  HOSPITAL
  REGULATOR
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  fullName          String
  organizationName  String?
  phone             String?

  role              UserRole

  isVerified        Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}